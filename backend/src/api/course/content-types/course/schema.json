{
	"kind": "collectionType",
	"collectionName": "courses",
	"info": {
		"singularName": "course",
		"pluralName": "courses",
		"displayName": "Course",
		"description": "Discipleship courses"
	},
	"options": {
		"draftAndPublish": true
	},
	"attributes": {
		"title": {
			"type": "string",
			"required": true
		},
		"slug": {
			"type": "uid",
			"targetField": "title",
			"required": true
		},
		"description": {
			"type": "richtext"
		},
		"image": {
			"type": "media",
			"multiple": false,
			"allowedTypes": ["images"]
		},
		"tags": {
			"type": "json"
		},
		"status": {
			"type": "enumeration",
			"enum": ["DRAFT", "COMING_SOON", "ACTIVE", "COMPLETED", "ARCHIVED"],
			"default": "DRAFT",
			"required": true
		},
		"startDate": {
			"type": "datetime"
		},
		"endDate": {
			"type": "datetime"
		},
		"schedule": {
			"type": "string"
		},
		"location": {
			"type": "string"
		},
		"whatsappMessage": {
			"type": "string"
		},
		"registrations": {
			"type": "relation",
			"relation": "oneToMany",
			"target": "api::registration.registration",
			"mappedBy": "course"
		}
	}
}
