{
  "name": "j25medellin",
  "private": true,
  "description": "J+ Medellin - Faith-based community web app",
  "scripts": {
    "dev": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend develop",
    "dev:all": "pnpm --parallel --filter frontend --filter backend dev",
    "build": "pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend build",
    "test": "pnpm --filter frontend test",
    "check": "biome check .",
    "check:fix": "biome check --fix ."
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "better-sqlite3",
      "core-js-pure",
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4"
  }
}
